    ( $Lxzp   0   $Lxzn )    // vertex number 41
    ( $Lxzp  $Liy $Lxzn )    // vertex number 42
    ( $Lip   $Liy $Lxzn )    // vertex number 43
	
	( $Lip    0   $Lxzp )    // vertex number 44
    ( $Lxzp   0   $Lxzp )    // vertex number 45
    ( $Lxzp  $Liy $Lxzp )    // vertex number 46
    ( $Lip   $Liy $Lxzp )    // vertex number 47
	
	// upper bulk region
    ( $Lxzn  $Liy $Lxzn )    // vertex number 48
    ( $Lxzp  $Liy $Lxzn )    // vertex number 49
    ( $Lxzp  $Ly  $Lxzn )    // vertex number 50
    ( $Lxzn  $Ly  $Lxzn )    // vertex number 51
    ( $Lxzn  $Liy $Lxzp )    // vertex number 52
    ( $Lxzp  $Liy $Lxzp )    // vertex number 53
    ( $Lxzp  $Ly  $Lxzp )    // vertex number 54
    ( $Lxzn  $Ly  $Lxzp )    // vertex number 55

);

// number of cells and expnsion ratio for one block with multigrading
nxz #eval{ 2*($dxzL) * $dx + 2*($di)};            // [-]; number of cells in the x and z directions
nyt  #eval{ ($dyL-2*$diL) * $dx + 2*($di) };      // [-]; number of cells in the y-direction
dxz_wall #eval{ $dxzL/(2*($diL+$dxzL)) };         // [%]; percentage of the x and z direction in the region near the wall 
dy_wall  #eval{ ($dyL-2*$diL)/($dyL) };           // [%]; percentage of the y direction in the region near the wall
dxz_core #eval{ 1/($diL+$dxzL) };                 // [%]; percentage of the x and z direction in the core region
dy_core  #eval{ 2*$diL/($dyL) };                  // [%]; percentage of the y direction in the core region
nxz_wall #eval{ $dxzL * $dx/$nxz };               // [%]; percentage of cells in the region near the wall in the x and z directions
ny_wall  #eval{ ($dyL-2*$diL)*($dx)/$nyt };       // [%]; percentage of cells in the region near the wall in the y direction
nxz_core #eval{ (2*$di)/$nxz };                   // [%]; percentage of cells in the core region in the x and z directions
ny_core  #eval{ (2*$di)/$nyt };                   // [%]; percentage of cells in the core region in the y direction

// number of cells in the refined region
nip   #eval{2*$diL * $di };  // [-]; number of cells

// number of cells in the lower bulk region
nixz #eval{ 2*$diL * $dx };   // [-]; number of cells in the x and z directions
nbxz #eval{ $dxzL * $dx };   // [-]; number of cells in the x and z directions
niy  #eval{2*$diL * $dx };   // [-]; number of cells in the y-direction

// number of cells in the upper bulk region
nxzu #eval{ 2*($diL+$dxzL) * $dx };     // [-]; number of cells in the x and z directions
nyu  #eval{ ($dyL-2*$diL) * $dx };   // [-]; number of cells in the y-direction

// number of cells and expnsion ratio for one block without multigrading
nxzs  #eval{ 2*($diL + $dxzL)* $dx};            // [-]; number of cells in the x and z directions
nyts  #eval{ ($dyL) * $dx };   // [-]; number of cells in the y-direction

