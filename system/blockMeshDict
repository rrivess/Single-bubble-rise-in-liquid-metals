scale 1;

// Geometrical details
db 5.76e-03;    // [m]; bubble diameter
diL 1;          // [m]; number of bubble diameters in the refined region
dxzL 3;         // [m]; number of bubble diameters in the bulk region
dyL 32;         // [m]; number of bubble diameters in the y-region
di 20;          // [-]; number of cell elements per unit diameter in the refined region
dx 10;           // [-]; number of cell elements per unit diameter in the bulk region

Lip #eval{ $diL * $db };   // m; length of the refined region in the positive direction
Liy #eval{2*$diL * $db };   // m; length of the refined region in the positive direction
Lin #eval{-$diL * $db };   // m; length of the refined region in the negative direction

Lxzp #eval{ ($diL+$dxzL) * $db };  // m; length of the domain in the positive x-direction
Lxzn #eval{-($diL+$dxzL) * $db };  // m; length of the domain in the negative x-direction
Ly   #eval{ $dyL * $db };          // m; length of the domain in the y-direction

vertices
(
    // refined region
    ( $Lin   0    $Lin )    // vertex number 0
    ( $Lip   0    $Lin )    // vertex number 1
    ( $Lip  $Liy  $Lin )    // vertex number 2
    ( $Lin  $Liy  $Lin )    // vertex number 3
    ( $Lin   0    $Lip )    // vertex number 4
    ( $Lip   0    $Lip )    // vertex number 5
    ( $Lip  $Liy  $Lip )    // vertex number 6
    ( $Lin  $Liy  $Lip )    // vertex number 7
	
	// lower bulk region
    ( $Lin   0    $Lxzn )    // vertex number 8
    ( $Lip   0    $Lxzn )    // vertex number 9
    ( $Lip  $Liy  $Lxzn )    // vertex number 10
    ( $Lin  $Liy  $Lxzn )    // vertex number 11
	
    ( $Lin   0    $Lxzp )    // vertex number 12
    ( $Lip   0    $Lxzp )    // vertex number 13
    ( $Lip  $Liy  $Lxzp )    // vertex number 14
    ( $Lin  $Liy  $Lxzp )    // vertex number 15
	
	( $Lxzn  0    $Lin )    // vertex number 16
    ( $Lin   0    $Lin )    // vertex number 17
    ( $Lin  $Liy  $Lin )    // vertex number 18
    ( $Lxzn $Liy  $Lin )    // vertex number 19
	( $Lxzn  0    $Lip )    // vertex number 20
