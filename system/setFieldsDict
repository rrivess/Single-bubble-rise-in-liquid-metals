FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultFieldValues
(
    volVectorFieldValue U (0 0 0)
);

regions
(
    // Bubble velocity perturbation
    sphereToCell
    {
        centre (0 0 3.5);
        radius 0.45;
        fieldValues
        (
            volVectorFieldValue U (1e-3 0 1e-3)
        );
    }
);


